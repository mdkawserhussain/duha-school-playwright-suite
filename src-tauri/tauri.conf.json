{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "School Portal Scraper",
  "version": "1.0.0",
  "identifier": "com.schoolportal.scraper",
  "build": {
    "beforeDevCommand": "npm run web:server",
    "beforeBuildCommand": "npm run web:build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "School Portal Scraper",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "targets": ["deb", "msi", "nsis", "app"],
    "resources": {
      "../src/": "_up_/src/",
      "../web/dist/": "_up_/web/dist/",
      "server-package.json": "package.json"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
