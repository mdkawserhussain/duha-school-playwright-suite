# School Management Portal Credentials (leave blank to use DUHA defaults)
PORTAL_USERNAME=""
PORTAL_PASSWORD=""

# Base URL of the School Portal
PORTAL_BASE_URL="https://duhais.eduexpert24.com"

# Dynamic filter criteria
PORTAL_YEAR="2026"
PORTAL_SHIFT="Day Shift"
PORTAL_CLASS="One"

# Spreadsheet column filter: comma-separated list of column name substrings to include in the Excel output.
# Matching is case-insensitive and partial — e.g. "session,january" will include any column
# whose name contains "session" or "january" (e.g. "Session Fee", "January Due").
# Identity columns (SL, Name, ID, Roll, Contact) are always included regardless.
# Leave empty to include ALL columns from the portal table.
#
# When combined with PORTAL_DUE_STUDENTS_ONLY=true, this also controls WHICH columns
# are checked for dues. E.g. REPORT_COLUMNS="january" means only students with dues
# specifically in the January column are included.
# REPORT_COLUMNS="january,session" → only students with dues in January OR Session Fee.
REPORT_COLUMNS=""

# Extractor toggles
EXTRACT_ATTENDANCE="false"
EXTRACT_ACCOUNTS_RECEIVABLE="true"

# Due-student filter: false = include all students, true (default) = only students with outstanding dues.
# When REPORT_COLUMNS is set, dues are only checked in those specific columns.
# When REPORT_COLUMNS is empty, dues are checked across ALL columns (Total Due, etc.)
PORTAL_DUE_STUDENTS_ONLY="true"
